node_modules/
dist/
*.log
.DS_Store
.vite/
coverage/
*.tsbuildinfo

# Belt-and-suspenders: tsconfig has noEmit so tsc shouldn't emit alongside
# .ts sources, but if it ever does we want it ignored.
src/**/*.js
src/**/*.d.ts
!src/vite-env.d.ts

# Generated by scripts/build-data.mjs from ../tariffs/*.yaml at build time.
# Source of truth is the YAML; do not edit JSON by hand.
public/tariffs.json
public/profiles.json

# Copied into public/ by build-data.mjs from the repo-root originals (the
# source of truth) so Vite serves them in dev and includes them in the build.
public/data_guide.html
public/manual.html
